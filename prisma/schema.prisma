generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model JsonStore {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  name               String
  role               String   @default("INTERN")
  mustChangePassword Boolean  @default(false)
  fcmToken           String?  @db.Text
  image              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  intern             Intern?
}

model Intern {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  user                   User      @relation(fields: [userId], references: [id])
  name                   String
  nim_nis                String
  email                  String?
  gender                 String    @default("Laki-laki")
  university             String
  jenjang                String    @default("S1")
  major                  String
  status                 String    @default("ACTIVE")
  bidang                 String
  wilayah                String?
  tahun                  String?
  periodStart            String?
  periodEnd              String?
  duration               String?
  phone                  String?
  nik                    String?
  birthDate              String?
  address                String?
  bankName               String?
  bankAccount            String?
  bankAccountName        String?
  supervisorName         String?
  supervisorTitle        String?
  suratPenerimaan        String?
  tanggalSuratPenerimaan String?
  spk                    String?
  tanggalSPK             String?
  amandemen              String?
  tanggalAmandemen       String?
  suratSelesai           String?
  tanggalSuratSelesai    String?
  fromImport             String?
  fromOnboarding         String?
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model AttendanceLog {
  id            String    @id @default(cuid())
  internId      String
  date          String
  checkIn       DateTime?
  checkOut      DateTime?
  status        String    @default("PRESENT")
  checkInLoc    String?
  checkOutLoc   String?
  faceInBase64  String?
  faceOutBase64 String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  editedAt      DateTime?
  editedBy      String?
  faceInUrl     String?
  faceOutUrl    String?
  isOverride    Boolean   @default(false)

  @@unique([internId, date])
}

model AttendanceCorrection {
  id         String    @id @default(cuid())
  internId   String
  internName String
  date       String
  type       String
  time       String
  reason     String
  status     String    @default("PENDING")
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([internId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  timestamp DateTime @default(now())
}

model DailyReport {
  id           String   @id @default(cuid())
  userId       String
  date         String
  activity     String
  supervisor   String?
  field        String?
  internName   String?
  nim_nis      String?
  status       String   @default("TERCATAT")
  commentText  String?
  reviewerId   String?
  reviewerName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isLiked      Boolean  @default(false)
  mood         String?
  challenges   String?
  nextWeek     String?
  skills       String[]
  isOverride   Boolean  @default(false)
}

model Onboarding {
  id          String    @id @default(cuid())
  status      String    @default("PENDING")
  applicant   Json
  docs        Json?
  catatan     String?
  reviewNote  String?
  reviewedBy  String?
  reviewedAt  DateTime?
  internId    String?
  timeline    Json?
  timestamp   DateTime  @default(now())
  submittedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Evaluation {
  id             String    @id @default(cuid())
  internId       String
  supervisorId   String    @default("u1")
  scores         Json
  finalScore     Float     @default(0)
  grade          String    @default("C")
  overallNote    String?
  period         String?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([internId])
}

model EvaluationCriteria {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  weight    Int      @default(15)
  desc      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model PayrollRecord {
  id                 String    @id @default(cuid())
  internId           String
  period             String
  status             String    @default("PENDING")
  presenceCount      Int       @default(0)
  validPresenceCount Int       @default(0)
  allowanceRate      Int       @default(25000)
  totalAllowance     Int       @default(0)
  paidAt             DateTime?
  paidBy             String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([internId, period])
  @@index([internId])
  @@index([status])
}

model Survey {
  id          String    @id @default(cuid())
  title       String
  description String?
  questions   Json
  targetRole  String    @default("INTERN")
  deadline    DateTime?
  active      Boolean   @default(true)
  createdBy   String    @default("Admin HR")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SurveyResponse {
  id             String   @id @default(cuid())
  surveyId       String
  respondentId   String   @default("anon")
  respondentName String   @default("Anonymous")
  respondentRole String   @default("INTERN")
  answers        Json
  submittedAt    DateTime @default(now())

  @@unique([surveyId, respondentId])
  @@index([surveyId])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  priority  String   @default("INFO")
  pinned    Boolean  @default(false)
  createdBy String   @default("Admin HR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        String
  type        String   @default("GENERAL")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HrTask {
  id        String   @id @default(cuid())
  title     String
  dueDate   String?
  priority  String   @default("MEDIUM")
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Recognition {
  id         String   @id @default(cuid())
  fromUserId String
  toInternId String
  message    String
  category   String   @default("TEAMWORK")
  createdAt  DateTime @default(now())

  @@index([toInternId])
  @@index([fromUserId])
}

model DepartmentQuota {
  id         String   @id @default(cuid())
  name       String   @unique
  quota      Int      @default(0)
  direktorat String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
