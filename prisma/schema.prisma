generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── JSON Store (replaces database.json on serverless) ───
model JsonStore {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

// ─── Core Auth & Profiles ─────────────────────────────────
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  name               String
  role               String   @default("INTERN")
  mustChangePassword Boolean  @default(false)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Intern {
  id                 String       @id @default(cuid())
  userId             String       @unique
  name               String
  nim_nis            String
  email              String?
  gender             String       @default("Laki-laki")
  university         String
  jenjang            String       @default("S1")
  major              String

  status             String       @default("ACTIVE")
  bidang             String
  wilayah            String?
  tahun              String?
  periodStart        String?
  periodEnd          String?
  duration           String?

  phone              String?
  nik                String?
  birthDate          String?
  address            String?

  bankName           String?
  bankAccount        String?
  bankAccountName    String?

  supervisorName     String?
  supervisorTitle    String?

  suratPenerimaan          String?
  tanggalSuratPenerimaan   String?
  spk                      String?
  tanggalSPK               String?
  amandemen                String?
  tanggalAmandemen         String?
  suratSelesai             String?
  tanggalSuratSelesai      String?

  fromImport         String?
  fromOnboarding     String?
  deletedAt          DateTime?



  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Attendance (migrated from SQLite) ────────────────────
model AttendanceLog {
  id            String   @id @default(cuid())
  internId      String


  date          String
  checkIn       DateTime?
  checkOut      DateTime?
  status        String   @default("PRESENT")

  checkInLoc    String?
  checkOutLoc   String?
  faceInBase64  String?  @db.Text
  faceOutBase64 String?  @db.Text

  // Supabase Storage URLs (preferred over Base64 - keeps DB lean)
  faceInUrl     String?
  faceOutUrl    String?

  // Admin manual edit audit trail
  editedBy      String?
  editedAt      DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([internId, date])
}

// ─── Audit Logs ───────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  timestamp DateTime @default(now())
}

// ─── Daily Reports ────────────────────────────────────────
model DailyReport {
  id          String   @id @default(cuid())
  userId      String
  date        String
  activity    String
  supervisor  String?
  field       String?
  internName  String?
  nim_nis     String?
  status      String   @default("TERCATAT") // DRAFT, TERCATAT, REVISION

  commentText String?
  reviewerId  String?
  reviewerName String?
  isLiked      Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Onboarding ───────────────────────────────────────────
model Onboarding {
  id          String   @id @default(cuid())
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, REVISION
  
  applicant   Json     // Store name, email, nim_nis, major etc as structured json
  docs        Json?    // Store doc URLs if any
  catatan     String?
  
  reviewNote  String?
  reviewedBy  String?
  reviewedAt  DateTime?

  internId    String?
  timeline    Json?

  timestamp   DateTime @default(now())
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Evaluations ------------------------------------------
model Evaluation {
  id             String    @id @default(cuid())
  internId       String
  supervisorId   String    @default("u1")
  scores         Json
  finalScore     Float     @default(0)
  grade          String    @default("C")
  overallNote    String?
  period         String?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([internId])
}

model EvaluationCriteria {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  weight    Int      @default(15)
  desc      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// --- Payroll ----------------------------------------------
model PayrollRecord {
  id                 String    @id @default(cuid())
  internId           String
  period             String
  status             String    @default("PENDING")
  presenceCount      Int       @default(0)
  validPresenceCount Int       @default(0)
  allowanceRate      Int       @default(25000)
  totalAllowance     Int       @default(0)
  paidAt             DateTime?
  paidBy             String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([internId, period])
  @@index([internId])
  @@index([status])
}

// --- Surveys ----------------------------------------------
model Survey {
  id          String    @id @default(cuid())
  title       String
  description String?
  questions   Json
  targetRole  String    @default("INTERN")
  deadline    DateTime?
  active      Boolean   @default(true)
  createdBy   String    @default("Admin HR")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SurveyResponse {
  id             String   @id @default(cuid())
  surveyId       String
  respondentId   String   @default("anon")
  respondentName String   @default("Anonymous")
  respondentRole String   @default("INTERN")
  answers        Json
  submittedAt    DateTime @default(now())

  @@unique([surveyId, respondentId])
  @@index([surveyId])
}

// --- Announcements ----------------------------------------
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  priority  String   @default("INFO")
  pinned    Boolean  @default(false)
  createdBy String   @default("Admin HR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Events (Calendar) ------------------------------------
model Event {
  id          String   @id @default(cuid())
  title       String
  date        String
  type        String   @default("GENERAL")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- HR Tasks ---------------------------------------------
model HrTask {
  id        String   @id @default(cuid())
  title     String
  dueDate   String?
  priority  String   @default("MEDIUM")
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
